<div class="cache-row-stack">
{% for row in scrape.rows %}
<article
  class="cache-row"
  id="cache-row-{{ row.group.label }}"
  {% if not row.research.researched %} data-unresearched="true"{% endif %}
>
  <header class="row-bookmark">
    <div class="row-bookmark-layers" aria-hidden="true"></div>
    <div class="row-bookmark-tab{% if not row.research.researched %} is-unresearched{% endif %}">
      <span class="row-bookmark-label">{{ row.group.label }}</span>
      <div class="row-bookmark-info">
        <div class="row-bookmark-meta">
          {% if row.group.tag %}<strong class="row-bookmark-tag">{{ row.group.tag }}</strong>{% endif %}
          {% if not row.research.researched %}
          <span class="tag not-researched-tag">Not researched</span>
          {% endif %}
        </div>
        {% if row.research.topic_summary %}
        <p class="row-bookmark-headline">{{ row.research.topic_summary }}</p>
        {% elif row.group.tag %}
        <p class="row-bookmark-headline row-bookmark-headline-muted">{{ row.group.tag }}</p>
        {% endif %}
      </div>
      <div class="row-bookmark-actions">
        <button
          type="button"
          class="fetch-images-btn"
          data-row="{{ row.group.label }}"
          title="Fetch tweet media; Tavily only if fewer than 5 tweet images"
          {% if not row.research.researched %}disabled data-perma-disabled title="Run full research on this row first"{% endif %}
        >Find images</button>
        <button
          type="button"
          class="slideshow-btn"
          data-slideshow-row="{{ row.group.label }}"
          {% if not row.research.images %}disabled{% endif %}
          title="Fullscreen Ken Burns slideshow"
        >Slideshow</button>
      </div>
    </div>
  </header>

  <div class="row-pages">
    {% if row.research.tweets %}
    <div class="tweet-grid">
      {% for tweet in row.research.tweets %}
        {% if tweet.image_url %}
        <a
          class="tweet-screenshot-link"
          href="{{ tweet.tweet_link or tweet.image_url }}"
          target="_blank"
          rel="noopener"
          title="{{ tweet.slot }}{% if tweet.handle %} · {{ tweet.handle }}{% endif %}"
        >
          <img
            class="tweet-screenshot"
            src="{{ tweet.image_url | display_image_url }}"
            alt="{{ tweet.slot }}"
            loading="lazy"
          >
        </a>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  <div class="cache-folds">
    {% if row.research.articles %}
    <details class="cache-fold">
      <summary class="cache-fold-summary">
        <span class="cache-fold-title">Articles</span>
        <span class="cache-fold-meta">{{ row.research.articles | length }}</span>
      </summary>
      <div class="cache-fold-body">
        {% for article in row.research.articles %}
        <details class="source-card">
          <summary>
            <span class="source-title">{{ article.title or article.url }}</span>
            <a href="{{ article.url }}" target="_blank" rel="noopener" onclick="event.stopPropagation()">↗</a>
          </summary>
          <pre class="source-body">{{ article.text[:4000] }}{% if article.text | length > 4000 %}…{% endif %}</pre>
        </details>
        {% endfor %}
      </div>
    </details>
    {% endif %}

    {% if row.research.search_results %}
    <details class="cache-fold">
      <summary class="cache-fold-summary">
        <span class="cache-fold-title">Search results</span>
        <span class="cache-fold-meta">{{ row.research.search_results | length }}</span>
      </summary>
      <div class="cache-fold-body">
        {% set ns = namespace(current_query='') %}
        {% for hit in row.research.search_results %}
          {% if hit.query != ns.current_query %}
            {% set ns.current_query = hit.query %}
            <p class="query-label"><code>{{ hit.query }}</code></p>
          {% endif %}
          <details class="source-card compact">
            <summary>
              <span class="source-title">{{ hit.title }}</span>
              <a href="{{ hit.url }}" target="_blank" rel="noopener" onclick="event.stopPropagation()">↗</a>
            </summary>
            <pre class="source-body">{{ hit.content[:2000] }}{% if hit.content | length > 2000 %}…{% endif %}</pre>
          </details>
        {% endfor %}
      </div>
    </details>
    {% endif %}

    <details class="cache-fold image-fold"{% if row.research.images %} open{% endif %}>
      <summary class="cache-fold-summary">
        <span class="cache-fold-title">Images</span>
        <span class="cache-fold-meta">{{ row.research.images | length }} saved</span>
      </summary>
      <div class="cache-fold-body image-block" data-image-block="{{ row.group.label }}">
        <p class="image-status" data-image-status="{{ row.group.label }}">
          {% if row.research.images %}
          {{ row.research.images | length }} saved image{{ "s" if row.research.images | length != 1 else "" }} (max 15). Drag ⠿ to reorder slideshow.
          {% else %}
          Click “Find images” to pull tweet media first; Tavily runs only if fewer than 5 tweet images. Use × to drop bad hits.
          {% endif %}
        </p>
        <div class="image-grid" data-image-grid="{{ row.group.label }}">
          {% for image in row.research.images %}
          <figure class="image-card">
            <button type="button" class="image-drag-handle" draggable="true" title="Drag to reorder slideshow" aria-label="Drag to reorder">⠿</button>
            <button type="button" class="image-remove-btn" title="Remove image" aria-label="Remove image">×</button>
            <button type="button" class="image-thumb-btn" title="Open slideshow">
              <img
                src="{{ image.url | display_image_url }}"
                data-raw-url="{{ image.url }}"
                alt="{{ image.description or 'Research image' }}"
                loading="lazy"
                onerror="this.closest('figure')?.classList.add('image-load-failed')"
              >
            </button>
            {% if image.description %}
            <figcaption>{{ image.description }}</figcaption>
            {% endif %}
            {% if image.source_url %}
            <p class="image-source"><a href="{{ image.source_url }}" target="_blank" rel="noopener">source</a></p>
            {% endif %}
          </figure>
          {% endfor %}
        </div>
      </div>
    </details>
  </div>
  </div>
</article>
{% endfor %}
</div>
