<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TBPN Rundown — {{ scrape.date_iso }}</title>
  <style>
    :root {
      --ink: #111;
      --muted: #555;
      --border: #ddd;
      --panel-bg: #fff;
      --page-bg: #f5f5f5;
      --accent: #1a1a1a;
      --success: #15803d;
      --success-bg: #ecfdf3;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: var(--page-bg);
      display: flex;
      flex-direction: column;
    }

    .topbar {
      background: var(--panel-bg);
      border-bottom: 1px solid var(--border);
      padding: 0.65rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .topbar h1 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 0;
      letter-spacing: -0.02em;
    }

    .topbar .date {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .topbar-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .btn {
      border: 1px solid var(--border);
      background: var(--panel-bg);
      color: var(--ink);
      font: inherit;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 0.42rem 0.78rem;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      line-height: 1.2;
    }

    .btn:hover:not(:disabled) { background: #eee; }

    .btn:disabled {
      opacity: 0.6;
      cursor: wait;
    }

    .btn-primary {
      border-color: var(--success);
      background: var(--success-bg);
      color: var(--success);
    }

    .btn-primary:hover:not(:disabled) {
      background: #dcfce7;
    }

    .btn-dark {
      border-color: var(--accent);
      background: var(--accent);
      color: #fff;
    }

    .btn-dark:hover:not(:disabled) {
      background: #333;
    }

    main {
      flex: 1;
      width: 100%;
      min-height: 0;
    }

    .rundown-frame {
      width: min(100%, 64rem);
      height: calc(100vh - 3.2rem);
      margin: 0 auto;
      display: block;
      border: 0;
      background: #fff;
    }

    .empty-state {
      width: min(44rem, calc(100% - 2rem));
      margin: 12vh auto 0;
      background: var(--panel-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem 1.75rem;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    }

    .empty-state h2 {
      margin: 0 0 0.7rem;
      font-size: 1.12rem;
    }

    .empty-state p {
      margin: 0 0 0.75rem;
      color: var(--muted);
      line-height: 1.5;
      font-size: 0.92rem;
    }

    .empty-state p:last-child { margin-bottom: 0; }

    .status {
      min-height: 1.2rem;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .status.error { color: #9a3412; }

    @media print {
      .topbar { display: none !important; }
      body { background: #fff; }
      .rundown-frame {
        width: 100%;
        height: auto;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <h1>TBPN Rundown</h1>
    <span class="date">{{ scrape.date_iso }}</span>
    <div class="topbar-actions">
      <button
        type="button"
        class="btn btn-primary"
        id="scrape-today-btn"
        title="Choose timeline rows, research them, and generate the rundown"
      >Choose sections</button>
      {% if has_debrief %}
      <a class="btn" href="debrief.html" target="_blank" rel="noopener">Open rundown</a>
      <a class="btn btn-primary" href="graphics.html">Create graphics</a>
      <a class="btn btn-dark" href="debrief.pdf" download="{{ fast_facts_pdf_filename(scrape.date_iso) }}">Download PDF</a>
      {% endif %}
    </div>
  </header>

  <main>
    {% if has_debrief %}
    <iframe class="rundown-frame" src="debrief.html" title="TBPN Rundown"></iframe>
    {% else %}
    <section class="empty-state">
      <h2>No rundown generated yet</h2>
      <p>
        Choose the timeline sections you want to research. After selection, the app will
        scrape those rows, generate the rundown, and open the finished page.
      </p>
      <p>
        This uses OpenAI for synthesis and may take a few minutes on larger days.
      </p>
      <p class="status" id="status"></p>
    </section>
    {% endif %}
  </main>

  <script>
    const canUseServer = window.location.protocol.startsWith('http');
    const scrapeBtn = document.getElementById('scrape-today-btn');
    const statusEl = document.getElementById('status');

    if (!canUseServer && scrapeBtn) {
      scrapeBtn.disabled = true;
      scrapeBtn.title = 'Start the local server with --serve';
      if (statusEl) {
        statusEl.textContent = 'Start the local server with python -m debrief --serve to generate a rundown.';
        statusEl.classList.add('error');
      }
    }

  </script>
  {% include "scrape_picker.html.j2" %}
</body>
</html>
