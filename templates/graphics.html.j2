<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TBPN Rundown Graphics — {{ debrief.date_iso }}</title>
  <style>
    @font-face {
      font-family: "Record Laser Freeze";
      src: url("graphics-assets/RecordLaserFreeze-TBPNMedium.ttf") format("truetype");
      font-display: block;
      font-style: normal;
      font-weight: 700;
    }

    @font-face {
      font-family: "Record Laser Freeze Medium";
      src: url("graphics-assets/RecordLaserFreeze-TBPNMedium.ttf") format("truetype");
      font-display: block;
      font-style: normal;
      font-weight: 400;
    }

    @font-face {
      font-family: "Record Laser Freeze";
      src: url("graphics-assets/RecordLaserFreeze-TBPNBoldItalic.ttf") format("truetype");
      font-display: block;
      font-style: italic;
      font-weight: 700;
    }

    @font-face {
      font-family: "Record Laser Freeze";
      src: url("graphics-assets/RecordLaserFreeze-TBPNBlack.ttf") format("truetype");
      font-display: block;
      font-style: normal;
      font-weight: 900;
    }

    :root {
      color-scheme: light;
      --green: #2fb081;
      --ink: #111;
      --muted: #555;
      --panel: #fff;
      --border: #ddd;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background: #f5f5f5;
      color: var(--ink);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    button, a { font: inherit; }

    .page-shell {
      width: min(1180px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 1.25rem 0 4rem;
    }

    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .intro {
      margin: 0;
      color: #111;
      font-size: 0.95rem;
      font-weight: 700;
      line-height: 1.5;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.65rem;
    }

    .button {
      appearance: none;
      border: 1px solid #ccc;
      border-radius: 0.75rem;
      background: #fff;
      color: var(--ink);
      cursor: pointer;
      display: inline-block;
      padding: 0.7rem 1rem;
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-decoration: none;
      text-transform: uppercase;
    }

    .button:hover { background: #eee; }
    .button:disabled { cursor: wait; opacity: 0.55; }

    .button-primary {
      border-color: var(--green);
      background: linear-gradient(
        90deg,
        rgb(66 148 96) 0%,
        rgb(66 148 98) 10%,
        rgb(66 148 96) 20%,
        rgb(67 149 99) 30%,
        rgb(61 137 90) 40%,
        rgb(56 128 88) 50%,
        rgb(51 115 80) 60%,
        rgb(47 109 75) 70%,
        rgb(41 96 68) 80%,
        rgb(34 82 58) 90%,
        rgb(31 77 55) 100%
      );
      color: #06120e;
    }

    .button-primary:hover { background: #45c493; }

    .button-dark {
      border-color: #111;
      background: #111;
      color: #fff;
    }

    .button-dark:hover { background: #333; }

    .cards { display: grid; gap: 1.25rem; }

    .card {
      display: grid;
      grid-template-columns: minmax(0, 640px) minmax(220px, 1fr);
      gap: 1.25rem;
      border: 1px solid var(--border);
      border-radius: 1rem;
      background: var(--panel);
      padding: 1.25rem;
      backdrop-filter: blur(8px);
    }

    .preview-wrap {
      position: relative;
      width: 100%;
      max-width: 640px;
      overflow: hidden;
    }

    .graphic-export {
      position: relative;
      width: 640px;
      height: 360px;
      overflow: hidden;
      background: #000;
      color: #fff;
      font-feature-settings: "lnum" 1, "tnum" 1;
      text-align: left;
      text-transform: uppercase;
    }

    .graphic-background {
      position: absolute;
      inset: 0;
      width: 640px;
      height: 360px;
      background: linear-gradient(135deg, #061713 0%, #0b3f31 55%, #061713 100%);
    }

    .fast-facts-label,
    .fact-text {
      position: absolute;
      display: flex;
      justify-content: flex-start;
      color: #fff;
      white-space: pre-line;
    }

    .fast-facts-label {
      left: 0;
      top: 0;
      width: 640px;
      height: 56px;
      align-items: center;
      padding-left: 32px;
      box-sizing: border-box;
      background-color: #00503d;
      background-image: linear-gradient(rgba(0, 80, 61, 0.82), rgba(0, 80, 61, 0.82)), url("graphics-assets/rundown-bg.png");
      background-position: center top;
      background-size: 640px 360px;
      border-bottom: 0;
      font: normal 900 24px/18px "Record Laser Freeze", Inter, sans-serif;
      justify-content: flex-start;
      text-align: left;
      text-shadow: none;
      letter-spacing: 0.05em;
    }

    .fast-facts-label::after {
      content: "";
      position: absolute;
      right: 0;
      bottom: 0;
      left: 0;
      height: 2px;
      background: #1a805f;
      pointer-events: none;
    }

    .facts-panel {
      position: absolute;
      left: 0;
      top: 56px;
      width: 640px;
      height: 304px;
      background: linear-gradient(
        180deg,
        #f5f5f5 0%,
        #f1f4f6 18%,
        #ecf2f4 40%,
        #ebeff3 60%,
        #e3eaf2 88%,
        #e4e5e6 100%
      );
      border-bottom: 0;
    }

    .facts-list {
      position: absolute;
      left: 34px;
      top: 22px;
      width: 572px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .fact-text {
      position: relative;
      left: auto;
      width: 100%;
      min-height: 20px;
      max-height: 40px;
      align-items: flex-start;
      overflow: hidden;
      padding-left: 0;
      background: transparent;
      color: #061713;
      font: normal 400 17px/20px "Record Laser Freeze Medium", "Record Laser Freeze", Inter, sans-serif;
      letter-spacing: 0;
      text-overflow: clip;
      text-transform: none;
      white-space: normal;
    }

    .fact-text::before {
      content: "■";
      display: inline-block;
      flex: 0 0 auto;
      margin-top: 5px;
      margin-right: 12px;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 8px;
      line-height: 1;
    }

    .fullscreen-button {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 0.7rem;
      background: rgba(0, 0, 0, 0.72);
      color: #fff;
      cursor: pointer;
      padding: 0.55rem 0.75rem;
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .card-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      min-width: 0;
      border: 1px solid #e5e5e5;
      border-radius: 0.8rem;
      background: #fafafa;
      padding: 1rem;
    }

    .facts-editor {
      width: 100%;
    }

    .facts-editor legend {
      display: block;
      margin: 0 0 0.45rem;
      color: #222;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.04em;
      line-height: 1.35;
    }

    .facts-editor {
      margin: 0;
      border: 0;
      padding: 0;
    }

    .facts-editor legend {
      padding: 0;
    }

    .editor-input {
      width: 100%;
      border: 1px solid #ccc;
      border-radius: 0.55rem;
      background: #fff;
      color: var(--ink);
      font: inherit;
      font-size: 0.85rem;
      line-height: 1.35;
      padding: 0.6rem 0.7rem;
    }

    .editor-input:focus {
      outline: 2px solid rgba(47, 176, 129, 0.35);
      border-color: var(--green);
    }

    .fact-editor-row {
      display: flex;
      align-items: flex-start;
      gap: 0.45rem;
      margin-top: 0.35rem;
    }

    .fact-editor-row.extra-fact-start {
      margin-top: 0.7rem;
      border-top: 1px solid #d8d8d8;
      padding-top: 0.55rem;
    }

    .fact-number {
      flex: 0 0 1.5rem;
      color: #888;
      font-size: 0.7rem;
      font-weight: 900;
      line-height: 2.25rem;
      text-align: center;
    }

    .fact-input {
      min-height: 2.05rem;
      resize: vertical;
    }

    .fact-input.graphic-fact {
      border-color: #2fb081;
      box-shadow: 0 0 0 2px rgba(47, 176, 129, 0.2);
    }

    .fact-input.extra-fact {
      border-color: #c84b4b;
      color: #777;
      box-shadow: 0 0 0 2px rgba(200, 75, 75, 0.18);
    }

    .facts-note {
      margin: -0.1rem 0 0.35rem;
      color: #777;
      font-size: 0.68rem;
      line-height: 1.3;
    }

    .row-badge {
      border: 1px solid var(--green);
      border-radius: 999px;
      background: var(--green);
      color: #06120e;
      padding: 0.35rem 0.75rem;
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .copy-label {
      margin: 0 0 0.35rem;
      color: #666;
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .copy-value {
      margin: 0;
      color: #333;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .fullscreen {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: grid;
      place-items: center;
      overflow: hidden;
      background: #000;
    }

    .fullscreen[hidden] { display: none; }

    .fullscreen-stage {
      width: 640px;
      height: 360px;
      transform-origin: center;
    }

    .standalone-graphic {
      min-height: 100vh;
      background: #000;
    }

    .standalone-graphic .page-shell {
      display: none;
    }

    @media (max-width: 980px) {
      .page-header { align-items: flex-start; flex-direction: column; }
      .actions { justify-content: flex-start; }
      .card { grid-template-columns: 1fr; }
      .preview-wrap { overflow-x: auto; }
    }
  </style>
</head>
<body>
  <main class="page-shell">
    <header class="page-header">
      <p class="intro">
        {{ debrief.rows | length }} graphics generated directly from the {{ debrief.date_iso }} rundown.
      </p>
      <div class="actions">
        <a class="button" href="debrief.html">Show rundown</a>
      </div>
    </header>

    <section class="cards">
      {% for row in debrief.rows %}
      <article class="card" data-row="{{ row.row }}">
        <div class="preview-wrap">
          <div
            class="graphic-export"
            data-row="{{ row.row }}"
          >
            <div class="graphic-background"></div>
            <div class="fast-facts-label">Fast facts:</div>
            <div class="facts-panel">
              <div class="facts-list">
                {% for fact in row.hard_facts[:max_facts] %}
                <div class="fact-text">{{ fact | graphic_text(fact_max_chars) }}</div>
                {% endfor %}
              </div>
            </div>
          </div>
          <button class="fullscreen-button" type="button">Fullscreen</button>
        </div>

        <div class="card-meta" data-row-editor data-row="{{ row.row }}">
          <fieldset class="facts-editor">
            <legend>{{ row.headline | graphic_text(90) }}</legend>
            <p class="facts-note">Green: on graphic · Red: rundown-only</p>
            {% for fact_index in range(editable_max_facts) %}
            {% set fact = row.hard_facts[fact_index] if fact_index < row.hard_facts | length else '' %}
            <div class="fact-editor-row{% if fact_index == max_facts %} extra-fact-start{% endif %}">
              <span class="fact-number">{{ fact_index + 1 }}</span>
              <textarea
                class="editor-input fact-input {{ 'graphic-fact' if fact_index < max_facts else 'extra-fact' }}"
                maxlength="{{ fact_max_chars }}"
                rows="1"
                aria-label="Fast fact {{ fact_index + 1 }}"
              >{{ fact }}</textarea>
            </div>
            {% endfor %}
          </fieldset>
        </div>
      </article>
      {% endfor %}
    </section>
  </main>

  <div class="fullscreen" id="fullscreen" hidden>
    <div class="fullscreen-stage" id="fullscreen-stage"></div>
  </div>

  <script>
    (() => {
      const PRESENTATION_WINDOW_NAME = 'tbpn-fast-facts';
      const fullscreen = document.getElementById('fullscreen');
      const fullscreenStage = document.getElementById('fullscreen-stage');
      const graphicNodes = [...document.querySelectorAll('.graphic-export')];
      const fullscreenParams = new URLSearchParams(window.location.search);
      const isStandalone = fullscreenParams.has('fullscreen');
      let fullscreenIndex = -1;

      function graphicText(text, maxChars) {
        const cleaned = text.replace(/\*\*(.+?)\*\*/g, '$1').trim();
        if (cleaned.length <= maxChars) return cleaned;
        const cut = cleaned.slice(0, maxChars);
        const lastSpace = cut.lastIndexOf(' ');
        return (lastSpace > maxChars - 18 ? cut.slice(0, lastSpace) : cut).trim();
      }

      function updateCardPreview(card) {
        const graphic = card.querySelector('.graphic-export');
        const facts = [...card.querySelectorAll('.fact-input')];
        const factTexts = facts.map((input) => graphicText(input.value, {{ fact_max_chars }}));
        const factsList = graphic.querySelector('.facts-list');
        factsList.replaceChildren(...factTexts.slice(0, {{ max_facts }}).filter(Boolean).map((fact) => {
          const element = document.createElement('div');
          element.className = 'fact-text';
          element.textContent = fact;
          return element;
        }));
      }

      function fitFullscreenStage() {
        const scale = Math.min(window.innerWidth / 640, window.innerHeight / 360);
        fullscreenStage.style.transform = `scale(${scale})`;
      }

      function showFullscreenGraphic(index, useNativeFullscreen = true) {
        if (!graphicNodes.length) return;
        fullscreenIndex = (index + graphicNodes.length) % graphicNodes.length;
        fullscreenStage.replaceChildren(graphicNodes[fullscreenIndex].cloneNode(true));
        fullscreen.hidden = false;
        fitFullscreenStage();
        if (useNativeFullscreen && !document.fullscreenElement) {
          fullscreen.requestFullscreen?.().catch(() => undefined);
        }
      }

      document.querySelectorAll('.card').forEach((card, index) => {
        const fullscreenButton = card.querySelector('.fullscreen-button');

        card.querySelectorAll('.fact-input').forEach((input) => {
          input.addEventListener('input', () => updateCardPreview(card));
        });

        fullscreenButton.addEventListener('click', () => {
          const fullscreenUrl = new URL(window.location.href);
          fullscreenUrl.searchParams.set('fullscreen', String(index));
          fullscreenUrl.searchParams.set(
            'facts',
            JSON.stringify([...card.querySelectorAll('.fact-input')].map((input) => input.value)),
          );
          const presentationWindow = window.open('', PRESENTATION_WINDOW_NAME);
          if (presentationWindow) {
            try {
              presentationWindow.location.href = fullscreenUrl.toString();
            } catch {
              presentationWindow.location.href = fullscreenUrl.toString();
            }
            presentationWindow.focus();
          }
        });
      });

      async function closeFullscreen() {
        if (isStandalone) {
          window.close();
          return;
        }
        fullscreen.hidden = true;
        fullscreenStage.replaceChildren();
        if (document.fullscreenElement) {
          await document.exitFullscreen().catch(() => undefined);
        }
      }

      document.addEventListener('keydown', (event) => {
        if (fullscreen.hidden) return;
        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
          event.preventDefault();
          showFullscreenGraphic(fullscreenIndex + 1);
        } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          event.preventDefault();
          showFullscreenGraphic(fullscreenIndex - 1);
        } else if (event.key === 'Escape') {
          closeFullscreen();
        }
      });
      window.addEventListener('resize', fitFullscreenStage);
      document.addEventListener('fullscreenchange', () => {
        if (isStandalone) {
          if (document.fullscreenElement === fullscreen) return;
          if (!document.fullscreenElement) closeFullscreen();
          return;
        }
        if (!document.fullscreenElement && !fullscreen.hidden) {
          fullscreen.hidden = true;
          fullscreenStage.replaceChildren();
        }
      });

      const standaloneIndex = Number.parseInt(
        fullscreenParams.get('fullscreen'),
        10,
      );
      if (Number.isInteger(standaloneIndex) && standaloneIndex >= 0 && standaloneIndex < graphicNodes.length) {
        const standaloneCard = document.querySelectorAll('.card')[standaloneIndex];
        const factsParam = fullscreenParams.get('facts');
        if (factsParam) {
          try {
            const facts = JSON.parse(factsParam);
            standaloneCard.querySelectorAll('.fact-input').forEach((input, factIndex) => {
              input.value = typeof facts[factIndex] === 'string' ? facts[factIndex] : '';
            });
            updateCardPreview(standaloneCard);
          } catch {
            // Use the generated facts if the opener's live edits were not encoded.
          }
        }
        document.body.classList.add('standalone-graphic');
        showFullscreenGraphic(standaloneIndex, false);
        window.requestAnimationFrame(() => {
          fullscreen.requestFullscreen?.().catch(() => {
            // The fixed presentation still fills the tab if fullscreen is unavailable.
          });
        });
      }

    })();
  </script>
</body>
</html>
